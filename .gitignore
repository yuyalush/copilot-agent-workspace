# ===== Python =====
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.venv/
venv/
*.egg

# ===== .NET =====
bin/
obj/
*.user
*.suo
*.userprefs
nul

# ===== 成果物 =====
# output/ は個人の調査結果・スライド等なので共有対象外
# 仕組み（skills, scripts, 設定）だけを共有する
# ディレクトリ構造は .gitkeep で保持
output/**
!output/**/
!output/**/.gitkeep

# ===== MCP データ =====
# memory MCP のデータは個人のセッション記憶なので共有対象外
.github/memory.json

# ===== 生成バイナリ =====
# presentations/*.pptx — チャレンジ要件のため Git 管理に含める

# ===== Challenge 提出固有 =====
# 提出フォーム用サマリー（社内コンテスト用）
docs/SUMMARY.md

# ===== OS =====
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ===== エディタ =====
*.swp
*.swo
*~
.idea/

# ===== VSCode =====
# mcp.json はプロジェクト設定なので追跡する
# .vscode/ 内のユーザー固有ファイルのみ除外
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json

# ===== Azure Infrastructure =====
# パラメータファイルには機密情報（GitHub PAT等）が含まれるため除外
infra/*.parameters.json
infra/*.parameters.*.json
# テンプレートファイル（サンプル）は保持
!infra/*.parameters.template.json
